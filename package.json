{
    "name": "@inluxc/stagehand",
    "version": "1.0.0",
    "description": "Extensible fixture toolkit for Playwright Test — adds OpenAPI, database, Kafka, Redis, mobile, and OTP fixtures on top of @playwright/test",
    "type": "module",
    "bin": {
        "stagehand": "dist/src/cli/init.js"
    },
    "main": "./dist/src/index.js",
    "module": "./dist/src/index.js",
    "types": "./dist/src/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/src/index.d.ts",
            "import": "./dist/src/index.js",
            "default": "./dist/src/index.js"
        },
        "./config": {
            "types": "./dist/src/config/index.d.ts",
            "import": "./dist/src/config/index.js"
        },
        "./fixtures": {
            "types": "./dist/src/fixtures/index.d.ts",
            "import": "./dist/src/fixtures/index.js"
        },
        "./secrets": {
            "types": "./dist/src/secrets/index.d.ts",
            "import": "./dist/src/secrets/index.js"
        },
        "./errors": {
            "types": "./dist/src/errors.d.ts",
            "import": "./dist/src/errors.js"
        },
        "./cli": {
            "types": "./dist/src/cli/init.d.ts",
            "import": "./dist/src/cli/init.js"
        }
    },
    "files": [
        "dist/src",
        "README.md",
        "LICENSE",
        "environments.json"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "clean": "rm -rf dist",
        "prebuild": "npm run clean",
        "prepublishOnly": "npm run build",
        "release": "npm run build && npm publish --access public",
        "release:dry": "npm run build && npm publish --dry-run --access public",
        "test": "npx playwright test",
        "test:tag": "npx playwright test --grep",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@mobilewright/test": "^0.0.35",
        "better-sqlite3": "^11.6.0",
        "dotenv": "^16.4.5",
        "graphql": "^16.14.0",
        "graphql-request": "^7.4.0",
        "ioredis": "^5.4.1",
        "kafkajs": "^2.2.4",
        "mobilewright": "^0.0.35",
        "mongodb": "^6.21.0",
        "mssql": "^11.0.1",
        "mysql2": "^3.11.0",
        "openapi-client-axios": "^7.5.5",
        "otplib": "^13.4.0",
        "pg": "^8.13.0"
    },
    "peerDependencies": {
        "@playwright/test": ">=1.50.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@types/better-sqlite3": "^7.6.0",
        "@types/mssql": "^12.3.0",
        "@types/node": "^22.0.0",
        "@types/pg": "^8.11.0",
        "fast-check": "^3.22.0",
        "tsx": "^4.19.0",
        "typescript": "^5.6.0"
    },
    "keywords": [
        "playwright",
        "playwright-test",
        "fixtures",
        "testing",
        "api",
        "openapi",
        "database",
        "mongodb",
        "kafka",
        "redis",
        "mobile",
        "otp",
        "integration",
        "extension",
        "stagehand"
    ],
    "author": "Inluxc",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Inluxc/stagehand.git"
    },
    "homepage": "https://github.com/Inluxc/stagehand#readme",
    "bugs": {
        "url": "https://github.com/Inluxc/stagehand/issues"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
